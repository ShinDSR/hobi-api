{
  "openapi": "3.0.0",
  "info": {
    "title": "Hobby API",
    "version": "1.0.0"
  },
  "paths": {
    "/api/hobbies": {
      "get": {
        "summary": "List My Hobbies",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "type": "array", "items": { "$ref": "#/components/schemas/Hobby" } },
                    "meta": { "$ref": "#/components/schemas/PaginationMeta" }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create Hobby",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string", "maxLength": 100 }
                },
                "required": ["name"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Hobby created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Hobby" }
              }
            }
          },
          "400": { "description": "Validation error" }
        }
      }
    },
    "/api/hobbies/{id}": {
      "get": {
        "summary": "Get Hobby by ID",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Hobby" }
              }
            }
          },
          "404": { "description": "Hobby not found" }
        }
      },
      "put": {
        "summary": "Update Hobby",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string", "maxLength": 100 }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Hobby updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Hobby" }
              }
            }
          },
          "400": { "description": "Validation error" },
          "404": { "description": "Hobby not found" }
        }
      },
      "delete": {
        "summary": "Delete Hobby",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Hobby deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "type": "string", "example": "OK" }
                  }
                }
              }
            }
          },
          "404": { "description": "Hobby not found" }
        }
      }
    },
    "/api/users/{user_id}/hobbies": {
      "get": {
        "summary": "List User's Hobbies (Admin only)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "user_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "type": "array", "items": { "$ref": "#/components/schemas/Hobby" } },
                    "meta": { "$ref": "#/components/schemas/PaginationMeta" }
                  }
                }
              }
            }
          },
          "403": { "description": "Forbidden (Non-admin)" }
        }
      },
      "post": {
        "summary": "Create User's Hobby (Admin only)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "user_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string", "maxLength": 100 }
                },
                "required": ["name"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Hobby created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Hobby" }
              }
            }
          },
          "400": { "description": "Validation error" },
          "403": { "description": "Forbidden (Non-admin)" }
        }
      }
    },
    "/api/users/{user_id}/hobbies/{hobby_id}": {
      "get": {
        "summary": "Get User's Hobby by ID (Admin only)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "user_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "hobby_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Successful operation",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Hobby" }
              }
            }
          },
          "404": { "description": "Hobby not found" },
          "403": { "description": "Forbidden (Non-admin)" }
        }
      },
      "put": {
        "summary": "Update User's Hobby (Admin only)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "user_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "hobby_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string", "maxLength": 100 }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Hobby updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Hobby" }
              }
            }
          },
          "400": { "description": "Validation error" },
          "404": { "description": "Hobby not found" },
          "403": { "description": "Forbidden (Non-admin)" }
        }
      },
      "delete": {
        "summary": "Delete User's Hobby (Admin only)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "user_id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "hobby_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Hobby deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": { "type": "string", "example": "OK" }
                  }
                }
              }
            }
          },
          "404": { "description": "Hobby not found" },
          "403": { "description": "Forbidden (Non-admin)" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Hobby": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "user": { "$ref": "#/components/schemas/User" }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "is_admin": { "type": "boolean" }
        }
      },
      "PaginationMeta": {
        "type": "object",
        "properties": {
          "current_page": { "type": "integer" },
          "last_page": { "type": "integer" },
          "per_page": { "type": "integer" },
          "total": { "type": "integer" }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
